{options
	{video
		{adapter "NVIDIA GeForce 256"}
		{resolution
			{custom_mode "1280x720"}
			{mode desktop}
		}
		{window_mode windowed_fullscreen}
		{preset min}
		{hdr 0}
		{vertical_sync}
		{antialiasing none}
		{fxaa 0}
		{detail detail_low}
		{shadow none}
		{filtering bilinear}
		{model_quality low}
		{fx_quality low}
		{bumpType none}
		{specular 0}
		{environment 0}
		{water_quality low}
		{grass 0}
		{lens_effects_options none}
		{lens_refraction 0}
		{dof 0}
		{softIntersection 0}
		{_ssao off}
		{fake_translucency 0}
		{glow 0}
		{rim_light 0}
		{filmGrain 0}
		{alphaToCoverage 0}
		{clip_distance 0.75}
	}
	{sound
		{speaker_config use_system_settings}
		{rate "44_khz"}
		{buffers "64"}
		{enable_hit_sound}
		{volume
			{master 80}
			{effects 80}
			{emotions 80}
			{environment 80}
			{interface 10}
			{game_music 5}
			{narrator 80}
		}
	}
	{game
		{difficulty easy}
		{fog_of_war fog_realistic}
		{manual_mode dc_mode}
		{subtitles}
		{invert_mouse_wheel 0}
		{invert_camera_third_person 0}
		{camera_scroll_speed 0.2}
		{camera_rotate_speed 1}
		{camera_speed_third_person 0.2}
		{mouseout_camera_movement}
		{camera_shakes 0}
		{hints}
		{action_by_left_click 0}
		{threat_markers}
		{global_chat}
		{autosave}
		{mouse_navigation}
		{show_scene_actor_buttons}
		{disable_mouse_actor_hints 0}
		{selection_circle
			{start_radius 64}
			{growth_per_second 256}
			{max_radius 256}
		}
		{multiplayer
			{userName GoH Mod Manager}
			{gameEnum ""}
			{message_chatwheel
				{message_chatwheel_team_v2 "3 6 7 1 2 0 9 8"}
				{message_chatwheel_allchat_v2 "3 6 7 1 2 0 9 8"}
			}
			{notification_chatwheel
				{chatwheel_variants "6"}
				{top attackhere}
				{topright defendhere}
				{bottomright enemyhere}
				{bottom goinghere}
				{bottomleft helphere}
				{topleft watchout}
			}
		}
	}
}
